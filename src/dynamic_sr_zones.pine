// ════════════════════════════════════════════════════════════════════
// Dynamic Support and Resistance Zones
// Version: 8.0 (Ground-up rebuild)
// Date: 2026-04-09
// Pine Script v6
// ════════════════════════════════════════════════════════════════════
// See README.md and docs/ for full development history and methodology.
// Published on TradingView as "Dynamic Support and Resistance Zones"
// ════════════════════════════════════════════════════════════════════

//@version=6
indicator("Dynamic Support and Resistance Zones", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=500)

// ══════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════

grpDetect = "Level Detection"
lookback      = input.int(5, "Pivot Lookback", minval=2, maxval=50, group=grpDetect)
maxLevels     = input.int(100, "Max Stored Levels", minval=10, maxval=500, group=grpDetect)
mergeMult     = input.float(1.5, "Merge Tolerance (ATR multiplier)", minval=0.1, step=0.1, group=grpDetect)
bandPct       = input.float(0.1, "Band Cluster (%)", minval=0.01, step=0.01, group=grpDetect)
filterTouch   = input.int(2, "Min Touches to Display", minval=1, maxval=10, group=grpDetect)
volFilter     = input.float(0.0, "Min Volume (x average)", minval=0.0, step=0.1, group=grpDetect)

grpDisplay = "Display"
showAbove     = input.int(4, "Levels Above Price", minval=1, maxval=20, group=grpDisplay)
showBelow     = input.int(4, "Levels Below Price", minval=1, maxval=20, group=grpDisplay)
lineExtend    = input.int(3, "Label Offset (bars)", minval=1, maxval=50, group=grpDisplay)
showLabels    = input.bool(true, "Show Price Labels", group=grpDisplay)
showLegend    = input.bool(true, "Show Legend", group=grpDisplay)
lblSize       = input.string("Normal", "Label Size", options=["Small", "Normal", "Large"], group=grpDisplay)
lblOverlap    = input.float(0.3, "Label Spacing (%)", minval=0.05, step=0.05, group=grpDisplay, tooltip="Labels closer than this % apart get staggered to avoid overlap")
zoneMergePct  = input.float(0.85, "Zone Merge (%)", minval=0.10, step=0.05, group=grpDisplay, tooltip="Nearby displayed levels are collapsed into one representative line + shaded zone")
legendBgAlpha = input.int(68, "Legend Background Opacity", minval=0, maxval=95, group=grpDisplay, tooltip="Lower = more opaque background (better contrast on light charts)")
legendHighContrastText = input.bool(true, "Legend High Contrast Text", group=grpDisplay)
enableStructAutoStagger = input.bool(true, "Auto Stagger Close Structural Labels", group=grpDisplay)
structLblOverlapPct = input.float(1.25, "Structural Label Spacing (%)", minval=0.05, step=0.05, group=grpDisplay, tooltip="Relative gap threshold; pairs like PWH vs PDL often need ~1%+ on sub-$100 names")
structLblGapAtrMult = input.float(0.50, "Structural Near (x ATR)", minval=0.05, step=0.05, group=grpDisplay, tooltip="Also treat as close when absolute gap is within this multiple of ATR (covers cases where %% looks small but labels still overlap)")
structLblOffsetAtrMult = input.float(0.10, "Structural Label Vertical Offset (ATR)", minval=0.01, step=0.01, group=grpDisplay)
structLblStaggerBoost = input.float(1.0, "Structural Stagger Strength", minval=0.5, maxval=4.0, step=0.25, group=grpDisplay, tooltip="Multiplies small vertical nudges when structural labels cluster (keep near 1.0 for stable charts)")

grpStruct = "Structural Levels"
showPDHL      = input.bool(true, "Previous Day High / Low", group=grpStruct)
showPWHL      = input.bool(true, "Previous Week High / Low", group=grpStruct)

grpColors = "Colors"
resColor      = input.color(color.new(color.red, 0), "Resistance", group=grpColors)
supColor      = input.color(color.new(color.green, 0), "Support", group=grpColors)
structColor   = input.color(color.new(color.white, 40), "Structural Levels", group=grpColors)
bandAlpha     = 85

debugMode     = input.bool(false, "Show Debug Info", group="Debug")

// ══════════════════════════════════════════
// SETUP
// ══════════════════════════════════════════

labelSz = lblSize == "Small" ? size.small : lblSize == "Large" ? size.large : size.normal

getTextColor(bgCol) =>
    r = color.r(bgCol)
    g = color.g(bgCol)
    b = color.b(bgCol)
    lum = 0.299 * r + 0.587 * g + 0.114 * b
    lum > 150 ? color.black : color.white

resTxtCol    = getTextColor(resColor)
supTxtCol    = getTextColor(supColor)
structTxtCol = getTextColor(structColor)
legendBodyText = legendHighContrastText ? color.white : structTxtCol

atrVal   = ta.atr(14)
mergeTol = atrVal * mergeMult
avgVol   = ta.sma(volume, 20)

structLblNearEnough(float pLo, float pHi, float atrV, float pctMax, float atrGapMult) =>
    float absGap = math.abs(pHi - pLo)
    float pctGap = pLo <= 0 ? 100.0 : absGap / pLo * 100
    bool byPct = pctGap < pctMax
    bool byAtr = not na(atrV) and atrV > 0 and absGap <= atrV * atrGapMult
    byPct or byAtr

// ══════════════════════════════════════════
// STRUCTURAL LEVELS
// ══════════════════════════════════════════

pdHigh = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_on)
pdLow  = request.security(syminfo.tickerid, "D", low[1],  lookahead=barmerge.lookahead_on)
pwHigh = request.security(syminfo.tickerid, "W", high[1], lookahead=barmerge.lookahead_on)
pwLow  = request.security(syminfo.tickerid, "W", low[1],  lookahead=barmerge.lookahead_on)

// ══════════════════════════════════════════
// PIVOT DETECTION + WICK SCORING
// ══════════════════════════════════════════

ph = ta.pivothigh(high, lookback, lookback)
pl = ta.pivotlow(low, lookback, lookback)
pivotVol = volume[lookback]
upperWick = high[lookback] - math.max(open[lookback], close[lookback])
lowerWick = math.min(open[lookback], close[lookback]) - low[lookback]

// ══════════════════════════════════════════
// LEVEL ARRAYS
// ══════════════════════════════════════════

var float[] lvlPrice      = array.new_float()
var int[]   lvlSupTouches = array.new_int()
var int[]   lvlResTouches = array.new_int()
var float[] lvlReaction   = array.new_float()
var int[]   lvlBars       = array.new_int()
var float[] lvlVol        = array.new_float()

var int dbg_ph = 0, var int dbg_pl = 0
var int dbg_vf = 0, var int dbg_mg = 0
var int dbg_nw = 0, var int dbg_tr = 0

isMerge(prices, price, tol) =>
    idx = -1
    if array.size(prices) > 0
        for i = 0 to array.size(prices) - 1
            if math.abs(array.get(prices, i) - price) < tol
                idx := i
                break
    idx

if not na(ph)
    dbg_ph += 1
    bool vP = na(avgVol) or avgVol == 0 ? true : (pivotVol / avgVol) >= volFilter
    if not vP
        dbg_vf += 1
    else
        rV = na(avgVol) or avgVol == 0 ? 1.0 : pivotVol / avgVol
        wQ = na(atrVal) or atrVal == 0 ? 1.0 : upperWick / atrVal
        m  = isMerge(lvlPrice, ph, mergeTol)
        if m >= 0
            dbg_mg += 1
            array.set(lvlPrice, m, (array.get(lvlPrice, m) + ph) / 2)
            array.set(lvlResTouches, m, array.get(lvlResTouches, m) + 1)
            array.set(lvlReaction, m, array.get(lvlReaction, m) + wQ)
            array.set(lvlBars, m, bar_index - lookback)
            array.set(lvlVol, m, math.max(array.get(lvlVol, m), rV))
        else
            dbg_nw += 1
            array.push(lvlPrice, ph)
            array.push(lvlSupTouches, 0)
            array.push(lvlResTouches, 1)
            array.push(lvlReaction, wQ)
            array.push(lvlBars, bar_index - lookback)
            array.push(lvlVol, rV)

if not na(pl)
    dbg_pl += 1
    bool vP = na(avgVol) or avgVol == 0 ? true : (pivotVol / avgVol) >= volFilter
    if not vP
        dbg_vf += 1
    else
        rV = na(avgVol) or avgVol == 0 ? 1.0 : pivotVol / avgVol
        wQ = na(atrVal) or atrVal == 0 ? 1.0 : lowerWick / atrVal
        m  = isMerge(lvlPrice, pl, mergeTol)
        if m >= 0
            dbg_mg += 1
            array.set(lvlPrice, m, (array.get(lvlPrice, m) + pl) / 2)
            array.set(lvlSupTouches, m, array.get(lvlSupTouches, m) + 1)
            array.set(lvlReaction, m, array.get(lvlReaction, m) + wQ)
            array.set(lvlBars, m, bar_index - lookback)
            array.set(lvlVol, m, math.max(array.get(lvlVol, m), rV))
        else
            dbg_nw += 1
            array.push(lvlPrice, pl)
            array.push(lvlSupTouches, 1)
            array.push(lvlResTouches, 0)
            array.push(lvlReaction, wQ)
            array.push(lvlBars, bar_index - lookback)
            array.push(lvlVol, rV)

// ══════════════════════════════════════════
// TRIM (score = reaction x dual x recency x vol / distance)
// ══════════════════════════════════════════

while array.size(lvlPrice) > maxLevels
    weakest = 0
    dual0 = (array.get(lvlSupTouches, 0) > 0 and array.get(lvlResTouches, 0) > 0) ? 2.0 : 1.0
    rec0  = 1.0 / (1.0 + (bar_index - array.get(lvlBars, 0)) / 500.0)
    dst0  = math.abs(array.get(lvlPrice, 0) - close) / close * 100
    wS    = array.get(lvlReaction, 0) * dual0 * rec0 * array.get(lvlVol, 0) / (1 + dst0)
    if array.size(lvlPrice) > 1
        for i = 1 to array.size(lvlPrice) - 1
            dual = (array.get(lvlSupTouches, i) > 0 and array.get(lvlResTouches, i) > 0) ? 2.0 : 1.0
            rec  = 1.0 / (1.0 + (bar_index - array.get(lvlBars, i)) / 500.0)
            dst  = math.abs(array.get(lvlPrice, i) - close) / close * 100
            sc   = array.get(lvlReaction, i) * dual * rec * array.get(lvlVol, i) / (1 + dst)
            if sc < wS
                wS := sc
                weakest := i
    array.remove(lvlPrice, weakest)
    array.remove(lvlSupTouches, weakest)
    array.remove(lvlResTouches, weakest)
    array.remove(lvlReaction, weakest)
    array.remove(lvlBars, weakest)
    array.remove(lvlVol, weakest)
    dbg_tr += 1

// ══════════════════════════════════════════
// DRAW
// ══════════════════════════════════════════

if barstate.islast
    int minOrigin = bar_index - 500
    int totalLvls = array.size(lvlPrice)

    var float[] aboveP = array.new_float(), var int[] aboveI = array.new_int()
    var float[] belowP = array.new_float(), var int[] belowI = array.new_int()
    array.clear(aboveP), array.clear(aboveI)
    array.clear(belowP), array.clear(belowI)

    for i = 0 to totalLvls - 1
        p = array.get(lvlPrice, i)
        if p >= close
            ins = false
            if array.size(aboveP) > 0
                for j = 0 to array.size(aboveP) - 1
                    if p < array.get(aboveP, j)
                        array.insert(aboveP, j, p), array.insert(aboveI, j, i)
                        ins := true
                        break
            if not ins
                array.push(aboveP, p), array.push(aboveI, i)
        else
            ins = false
            if array.size(belowP) > 0
                for j = 0 to array.size(belowP) - 1
                    if p > array.get(belowP, j)
                        array.insert(belowP, j, p), array.insert(belowI, j, i)
                        ins := true
                        break
            if not ins
                array.push(belowP, p), array.push(belowI, i)

    var int[] drawList = array.new_int()
    array.clear(drawList)
    int aC = math.min(showAbove, array.size(aboveI))
    if aC > 0
        for i = 0 to aC - 1
            array.push(drawList, array.get(aboveI, i))
    int bC = math.min(showBelow, array.size(belowI))
    if bC > 0
        for i = 0 to bC - 1
            array.push(drawList, array.get(belowI, i))

    var float[] cP = array.new_float()
    var int[] cST = array.new_int(), var int[] cRT = array.new_int()
    var float[] cRe = array.new_float(), var float[] cVo = array.new_float()
    var int[] cOr = array.new_int()
    array.clear(cP), array.clear(cST), array.clear(cRT)
    array.clear(cRe), array.clear(cVo), array.clear(cOr)

    if array.size(drawList) > 0
        for d = 0 to array.size(drawList) - 1
            i  = array.get(drawList, d)
            tT = array.get(lvlSupTouches, i) + array.get(lvlResTouches, i)
            if tT >= filterTouch
                array.push(cP, array.get(lvlPrice, i))
                array.push(cST, array.get(lvlSupTouches, i))
                array.push(cRT, array.get(lvlResTouches, i))
                array.push(cRe, array.get(lvlReaction, i))
                array.push(cVo, array.get(lvlVol, i))
                array.push(cOr, math.max(array.get(lvlBars, i), minOrigin))

    int cn = array.size(cP)
    if cn > 1
        for i = 0 to cn - 2
            for j = i + 1 to cn - 1
                if array.get(cP, i) > array.get(cP, j)
                    tF = array.get(cP, i), array.set(cP, i, array.get(cP, j)), array.set(cP, j, tF)
                    tI = array.get(cST, i), array.set(cST, i, array.get(cST, j)), array.set(cST, j, tI)
                    tI := array.get(cRT, i), array.set(cRT, i, array.get(cRT, j)), array.set(cRT, j, tI)
                    tF := array.get(cRe, i), array.set(cRe, i, array.get(cRe, j)), array.set(cRe, j, tF)
                    tF := array.get(cVo, i), array.set(cVo, i, array.get(cVo, j)), array.set(cVo, j, tF)
                    tI := array.get(cOr, i), array.set(cOr, i, array.get(cOr, j)), array.set(cOr, j, tI)

    var float[] bAn = array.new_float(), var float[] bTo = array.new_float(), var float[] bBo = array.new_float()
    var int[] bST2 = array.new_int(), var int[] bRT2 = array.new_int()
    var float[] bRe = array.new_float(), var float[] bVo = array.new_float(), var int[] bOr = array.new_int()
    array.clear(bAn), array.clear(bTo), array.clear(bBo)
    array.clear(bST2), array.clear(bRT2), array.clear(bRe), array.clear(bVo), array.clear(bOr)

    var bool[] used = array.new_bool()
    array.clear(used)
    if cn > 0
        for i = 0 to cn - 1
            array.push(used, false)

    if cn > 0
        for i = 0 to cn - 1
            if not array.get(used, i)
                aP = array.get(cP, i), aS = array.get(cST, i), aR = array.get(cRT, i)
                aRe = array.get(cRe, i), aVo = array.get(cVo, i), aOr = array.get(cOr, i)
                aSc = aRe * aVo, tTop = aP, tBot = aP
                bP = aP, bSc = aSc, bRe2 = aRe, bVo2 = aVo, bOr2 = aOr
                array.set(used, i, true)
                if i < cn - 1
                    for j = i + 1 to cn - 1
                        if not array.get(used, j)
                            jP = array.get(cP, j)
                            if math.abs(jP - bP) / bP * 100 <= bandPct
                                array.set(used, j, true)
                                tTop := math.max(tTop, jP), tBot := math.min(tBot, jP)
                                aS += array.get(cST, j), aR += array.get(cRT, j)
                                jSc = array.get(cRe, j) * array.get(cVo, j)
                                if jSc > bSc
                                    bSc := jSc, bP := jP, bRe2 := array.get(cRe, j)
                                    bVo2 := array.get(cVo, j), bOr2 := array.get(cOr, j)
                array.push(bAn, bP), array.push(bTo, tTop), array.push(bBo, tBot)
                array.push(bST2, aS), array.push(bRT2, aR)
                array.push(bRe, bRe2), array.push(bVo, bVo2), array.push(bOr, bOr2)

    // ── Unified label system (anti-overlap) ──
    var float[] allLblPrice = array.new_float(), var string[] allLblText = array.new_string()
    var color[] allLblColor = array.new_color(), var color[] allLblTxtCol = array.new_color()
    var int[] allLblBar = array.new_int(), var int[] allLblLw = array.new_int()
    var int[] allLblOrigin = array.new_int(), var bool[] allLblStruct = array.new_bool()
    var float[] allLblYAdj = array.new_float()
    array.clear(allLblPrice), array.clear(allLblText), array.clear(allLblColor)
    array.clear(allLblTxtCol), array.clear(allLblBar), array.clear(allLblLw)
    array.clear(allLblOrigin), array.clear(allLblStruct), array.clear(allLblYAdj)

    if showPDHL and not na(pdHigh)
        array.push(allLblPrice, pdHigh), array.push(allLblText, "PDH " + str.tostring(pdHigh, format.mintick))
        array.push(allLblColor, structColor), array.push(allLblTxtCol, structTxtCol)
        array.push(allLblBar, bar_index + lineExtend + 1), array.push(allLblLw, 1)
        array.push(allLblOrigin, bar_index - 60), array.push(allLblStruct, true)
        array.push(allLblYAdj, 0.0)
    if showPDHL and not na(pdLow)
        array.push(allLblPrice, pdLow), array.push(allLblText, "PDL " + str.tostring(pdLow, format.mintick))
        array.push(allLblColor, structColor), array.push(allLblTxtCol, structTxtCol)
        array.push(allLblBar, bar_index + lineExtend + 1), array.push(allLblLw, 1)
        array.push(allLblOrigin, bar_index - 60), array.push(allLblStruct, true)
        array.push(allLblYAdj, 0.0)
    if showPWHL and not na(pwHigh)
        array.push(allLblPrice, pwHigh), array.push(allLblText, "PWH " + str.tostring(pwHigh, format.mintick))
        array.push(allLblColor, structColor), array.push(allLblTxtCol, structTxtCol)
        array.push(allLblBar, bar_index + lineExtend + 1), array.push(allLblLw, 2)
        array.push(allLblOrigin, bar_index - 120), array.push(allLblStruct, true)
        array.push(allLblYAdj, 0.0)
    if showPWHL and not na(pwLow)
        array.push(allLblPrice, pwLow), array.push(allLblText, "PWL " + str.tostring(pwLow, format.mintick))
        array.push(allLblColor, structColor), array.push(allLblTxtCol, structTxtCol)
        array.push(allLblBar, bar_index + lineExtend + 1), array.push(allLblLw, 2)
        array.push(allLblOrigin, bar_index - 120), array.push(allLblStruct, true)
        array.push(allLblYAdj, 0.0)

    int bCount = array.size(bAn)
    if bCount > 0
        for i = 0 to bCount - 1
            anchor = array.get(bAn, i)
            sT = array.get(bST2, i), rT = array.get(bRT2, i), tT = sT + rT
            rV = array.get(bVo, i), isDual = sT > 0 and rT > 0
            isAbove = anchor >= close
            lCol = isAbove ? resColor : supColor, tCol = isAbove ? resTxtCol : supTxtCol
            lw = tT >= 6 ? 3 : tT >= 3 ? 2 : 1
            if rV >= 2.0
                lw += 1
            lw := math.min(lw, 4)
            typeStr = isAbove ? "R" : "S"
            dualStr = isDual ? " ◆" : ""
            volStr = rV >= 1.5 ? " ★" : ""
            touchStr = isDual ? str.tostring(sT) + "s/" + str.tostring(rT) + "r" : str.tostring(tT) + "x"
            lblText = str.tostring(anchor, format.mintick) + " " + typeStr + " (" + touchStr + ")" + dualStr + volStr
            array.push(allLblPrice, anchor), array.push(allLblText, lblText)
            array.push(allLblColor, lCol), array.push(allLblTxtCol, tCol)
            array.push(allLblBar, bar_index + lineExtend + 1), array.push(allLblLw, lw)
            array.push(allLblOrigin, array.get(bOr, i)), array.push(allLblStruct, false)
            array.push(allLblYAdj, 0.0)

    int allN = array.size(allLblPrice)
    if allN > 1
        for i = 0 to allN - 2
            for j = i + 1 to allN - 1
                if array.get(allLblPrice, i) > array.get(allLblPrice, j)
                    tF = array.get(allLblPrice, i), array.set(allLblPrice, i, array.get(allLblPrice, j)), array.set(allLblPrice, j, tF)
                    tS = array.get(allLblText, i), array.set(allLblText, i, array.get(allLblText, j)), array.set(allLblText, j, tS)
                    tC = array.get(allLblColor, i), array.set(allLblColor, i, array.get(allLblColor, j)), array.set(allLblColor, j, tC)
                    tC := array.get(allLblTxtCol, i), array.set(allLblTxtCol, i, array.get(allLblTxtCol, j)), array.set(allLblTxtCol, j, tC)
                    tI = array.get(allLblBar, i), array.set(allLblBar, i, array.get(allLblBar, j)), array.set(allLblBar, j, tI)
                    tI := array.get(allLblLw, i), array.set(allLblLw, i, array.get(allLblLw, j)), array.set(allLblLw, j, tI)
                    tI := array.get(allLblOrigin, i), array.set(allLblOrigin, i, array.get(allLblOrigin, j)), array.set(allLblOrigin, j, tI)
                    tB = array.get(allLblStruct, i), array.set(allLblStruct, i, array.get(allLblStruct, j)), array.set(allLblStruct, j, tB)
                    tY = array.get(allLblYAdj, i), array.set(allLblYAdj, i, array.get(allLblYAdj, j)), array.set(allLblYAdj, j, tY)

    var bool[] skipLbl = array.new_bool()
    array.clear(skipLbl)
    if allN > 0
        for i = 0 to allN - 1
            array.push(skipLbl, false)

    if allN > 1
        for i = 0 to allN - 1
            if array.get(allLblStruct, i) and not array.get(skipLbl, i)
                sPrice = array.get(allLblPrice, i)
                sTag = array.get(allLblText, i)
                tag = str.substring(sTag, 0, 3)
                for j = 0 to allN - 1
                    if j != i and not array.get(allLblStruct, j) and not array.get(skipLbl, j)
                        pPrice = array.get(allLblPrice, j)
                        if math.abs(sPrice - pPrice) / pPrice * 100 <= lblOverlap
                            array.set(allLblText, j, array.get(allLblText, j) + " [" + tag + "]")
                            break

    int maxLblBar = bar_index + lineExtend + 7
    float pxTick = syminfo.mintick
    float priceOff = na(atrVal) or atrVal == 0 ? pxTick * 5.0 : atrVal * structLblOffsetAtrMult
    float minOff = pxTick * 3.0
    float maxOff = pxTick * 50.0
    if priceOff < minOff
        priceOff := minOff
    if priceOff > maxOff
        priceOff := maxOff

    float yAmtBase = math.max(priceOff, pxTick * 14.0)
    yAmtBase := math.max(yAmtBase, na(atrVal) or atrVal == 0 ? pxTick * 14.0 : atrVal * 0.12)

    // Structural stagger uses structural labels only (sorted by price). Pivot labels between PDL and PWH
    // no longer break the chain (they sat between those levels in the unified sorted list).
    var int[] stIx = array.new_int()
    array.clear(stIx)
    if allN > 0
        for i = 0 to allN - 1
            if array.get(allLblStruct, i) and not array.get(skipLbl, i)
                array.push(stIx, i)
    int stN = array.size(stIx)
    if enableStructAutoStagger and stN > 1
        for i = 0 to stN - 2
            for j = i + 1 to stN - 1
                int ixa = array.get(stIx, i)
                int ixb = array.get(stIx, j)
                if array.get(allLblPrice, ixa) > array.get(allLblPrice, ixb)
                    array.set(stIx, i, ixb)
                    array.set(stIx, j, ixa)
        int s = 0
        while s < stN
            int e = s
            while e < stN - 1
                int ixA = array.get(stIx, e)
                int ixB = array.get(stIx, e + 1)
                float pA = array.get(allLblPrice, ixA)
                float pB = array.get(allLblPrice, ixB)
                if pA <= 0
                    break
                if not structLblNearEnough(pA, pB, atrVal, structLblOverlapPct, structLblGapAtrMult)
                    break
                e := e + 1
            if e > s
                float pClLo = array.get(allLblPrice, array.get(stIx, s))
                float pClHi = array.get(allLblPrice, array.get(stIx, e))
                float span = pClHi - pClLo
                float halfSep = math.max(yAmtBase, span * 0.22 + pxTick * 8.0)
                halfSep := math.max(halfSep, na(atrVal) or atrVal == 0 ? pxTick * 12.0 : atrVal * 0.14)
                halfSep := halfSep * structLblStaggerBoost
                float capAtr = na(atrVal) or atrVal == 0 ? pxTick * 40.0 : atrVal * 0.42
                float capPct = na(close) or close == 0 ? capAtr : close * 0.0035
                halfSep := math.min(halfSep, math.min(capAtr, capPct))
                for k = s to e
                    int ixK = array.get(stIx, k)
                    // Cluster list is ascending price: lower label nudged down (-), higher up (+)
                    float sgn = (k - s) % 2 == 0 ? -1.0 : 1.0
                    array.set(allLblYAdj, ixK, sgn * halfSep)
                    int step = (k - s) * 3
                    int nb = bar_index + lineExtend + 1 + step
                    array.set(allLblBar, ixK, math.min(nb, maxLblBar))
            s := e + 1

    if allN > 1
        for i = 1 to allN - 1
            if not array.get(skipLbl, i) and not array.get(skipLbl, i - 1)
                p1 = array.get(allLblPrice, i - 1)
                p2 = array.get(allLblPrice, i)
                if p1 > 0
                    float pct = math.abs(p2 - p1) / p1 * 100
                    bool s1 = array.get(allLblStruct, i - 1)
                    bool s2 = array.get(allLblStruct, i)
                    bool structPairClose = s1 and s2 and enableStructAutoStagger and structLblNearEnough(p1, p2, atrVal, structLblOverlapPct, structLblGapAtrMult)
                    if pct < lblOverlap and not structPairClose
                        curBar = array.get(allLblBar, i)
                        array.set(allLblBar, i, math.min(curBar + 8, maxLblBar))

    // ── Final render pass: collapse close displayed levels into representative zones ──
    var int[] actIx = array.new_int()
    array.clear(actIx)
    if allN > 0
        for i = 0 to allN - 1
            if not array.get(skipLbl, i)
                array.push(actIx, i)

    int actN = array.size(actIx)
    if actN > 0
        int s = 0
        while s < actN
            int e = s
            while e < actN - 1
                int ixA = array.get(actIx, e)
                int ixB = array.get(actIx, e + 1)
                pA = array.get(allLblPrice, ixA)
                pB = array.get(allLblPrice, ixB)
                if pA <= 0
                    break
                pctGap = math.abs(pB - pA) / pA * 100
                if pctGap > zoneMergePct
                    break
                e := e + 1

            int repIx = array.get(actIx, s)
            zTop = array.get(allLblPrice, repIx)
            zBot = zTop
            zOrigin = array.get(allLblOrigin, repIx)
            zBar = array.get(allLblBar, repIx)
            allStructInZone = array.get(allLblStruct, repIx)
            bestLw = array.get(allLblLw, repIx)

            if e > s
                for k = s to e
                    ixK = array.get(actIx, k)
                    pk = array.get(allLblPrice, ixK)
                    zTop := math.max(zTop, pk)
                    zBot := math.min(zBot, pk)
                    zOrigin := math.min(zOrigin, array.get(allLblOrigin, ixK))
                    zBar := math.max(zBar, array.get(allLblBar, ixK))
                    allStructInZone := allStructInZone and array.get(allLblStruct, ixK)
                    lwK = array.get(allLblLw, ixK)
                    // Prefer strongest line width; break ties in favor of non-structural label.
                    if lwK > bestLw or (lwK == bestLw and not array.get(allLblStruct, ixK) and array.get(allLblStruct, repIx))
                        repIx := ixK
                        bestLw := lwK

            repPrice = e > s ? (zTop + zBot) / 2.0 : array.get(allLblPrice, repIx)
            repColor = array.get(allLblColor, repIx)
            repTxtCol = array.get(allLblTxtCol, repIx)
            repLw = array.get(allLblLw, repIx)
            repSty = allStructInZone ? line.style_dashed : line.style_solid
            repText = array.get(allLblText, repIx)
            if e > s and not allStructInZone
                repText := repText + " ▒"
            if e > s and allStructInZone
                repText := "STRUCT " + str.tostring(repPrice, format.mintick)

            line.new(zOrigin, repPrice, bar_index + lineExtend, repPrice, color=repColor, width=repLw, style=repSty)
            if e > s and zTop != zBot
                box.new(zOrigin, zTop, bar_index + lineExtend, zBot, bgcolor=color.new(repColor, bandAlpha), border_color=color.new(repColor, 90))

            if showLabels
                label.new(zBar, repPrice, repText, style=label.style_label_left, color=repColor, textcolor=repTxtCol, size=labelSz)

            s := e + 1

    var table legTbl = table.new(position.top_right, 1, 8, bgcolor=color.new(color.gray, legendBgAlpha), border_width=0)
    if showLegend
        table.cell(legTbl, 0, 0, "── LEGEND ──", text_color=legendBodyText, text_size=size.small, text_halign=text.align_left)
        table.cell(legTbl, 0, 1, "━ Support (S): level below price", text_color=supColor, text_size=size.small, text_halign=text.align_left)
        table.cell(legTbl, 0, 2, "━ Resistance (R): level above price", text_color=resColor, text_size=size.small, text_halign=text.align_left)
        table.cell(legTbl, 0, 3, "┄ PDH/PDL  PWH/PWL: structural levels", text_color=structColor, text_size=size.small, text_halign=text.align_left)
        table.cell(legTbl, 0, 4, "◆ = dual role (acted as both S and R)", text_color=legendBodyText, text_size=size.small, text_halign=text.align_left)
        table.cell(legTbl, 0, 5, "★ = high volume pivot (1.5x+ avg)", text_color=legendBodyText, text_size=size.small, text_halign=text.align_left)
        table.cell(legTbl, 0, 6, "Line width = reaction strength + touches", text_color=legendBodyText, text_size=size.small, text_halign=text.align_left)
        table.cell(legTbl, 0, 7, "[PWH] = coincides with structural level", text_color=legendBodyText, text_size=size.small, text_halign=text.align_left)

    var table dbgTbl = table.new(position.bottom_left, 1, 1, bgcolor=color.new(color.gray, legendBgAlpha), border_width=0)
    if debugMode
        string dump = ""
        int dc = math.min(bCount, 5)
        if dc > 0
            for i = 0 to dc - 1
                p = array.get(bAn, i), s = array.get(bST2, i), r = array.get(bRT2, i)
                re = array.get(bRe, i), v = array.get(bVo, i)
                dump += "\n " + str.tostring(p, format.mintick) + " " + (p >= close ? "R" : "S") + " " + str.tostring(s) + "s/" + str.tostring(r) + "r wk:" + str.tostring(re, "#.##") + " vol:" + str.tostring(v, "#.##") + (s > 0 and r > 0 ? " DUAL" : "")
        txt = "═══ DEBUG ═══" +
             "\nPivot H/L: " + str.tostring(dbg_ph) + " / " + str.tostring(dbg_pl) +
             "\nMerged: " + str.tostring(dbg_mg) + "  New: " + str.tostring(dbg_nw) +
             "\nTrimmed: " + str.tostring(dbg_tr) + "\nStored: " + str.tostring(totalLvls) +
             "\nBands: " + str.tostring(bCount) + "\nATR: " + str.tostring(atrVal, "#.##") +
             "\n── Top 5 ──" + dump
        table.cell(dbgTbl, 0, 0, txt, text_color=color.white, text_size=size.small, text_halign=text.align_left)
